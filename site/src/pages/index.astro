---
import ArtifactCard from "@components/ArtifactCard.astro";
import CommandCard from "@components/CommandCard.astro";
import EpisodeCard from "@components/EpisodeCard.astro";
import EvalMetricCard from "@components/EvalMetricCard.astro";
import FinalCTA from "@components/FinalCTA.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Hero from "@components/Hero.astro";
import InstallBlock from "@components/InstallBlock.astro";
import PipelineDiagram from "@components/PipelineDiagram.astro";
import RefusalCard from "@components/RefusalCard.astro";
import TerminalCard from "@components/TerminalCard.astro";
import {
  artifacts,
  commands,
  comparisonRows,
  messAfter,
  messBefore,
  metrics,
  refusals
} from "@data/home";
import "@styles/global.css";

const title = "pc - Provenance-first context for AI agents";
const description =
  "pc captures human judgment from agent sessions, distills it into a cited project wiki, and injects the relevant context before the agent acts again.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08090A" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og.svg" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main id="content">
      <Hero />

      <section id="problem" class="section problem-section" aria-labelledby="problem-heading">
        <div class="section-intro problem-intro">
          <p class="eyebrow">The correction is the asset</p>
          <h2 id="problem-heading">The valuable part of an agent session is rarely the transcript.</h2>
          <p>
            It is the moment you corrected the model. The abstraction you rejected.
            The constraint you clarified. The reversal you made after watching the system fight back.
          </p>
          <p>
            pc captures those moments as cited project knowledge, not as a fog of embeddings.
          </p>
        </div>

        <div class="correction-transform">
          <article class="transcript-snippet surface is-amber" aria-label="Line-numbered correction transcript">
            <div class="card-meta">
              <span class="badge is-amber">transcript</span>
              <code>session:105d3450 · lines 127-130</code>
            </div>
            <div class="source-lines">
              <p><span>127</span><b>assistant</b> I'll position this as a generic memory category.</p>
              <p class="highlight"><span>128</span><b>user</b> No. Do not make this a generic memory system.</p>
              <p class="highlight"><span>129</span><b>user</b> The point is provenance over fluency.</p>
              <p><span>130</span><b>assistant</b> Understood.</p>
            </div>
          </article>

          <div class="transform-line" aria-hidden="true">
            <span>human correction</span>
            <span>cited claim</span>
            <span>wiki artifact</span>
            <span>injected briefing</span>
          </div>

          <article class="claim-card surface is-green" aria-label="Verified claim card">
            <div class="claim-row">
              <span>claim</span>
              <p>The project rejects generic memory positioning and anchors on provenance over fluency.</p>
            </div>
            <div class="claim-row">
              <span>source</span>
              <p>session:105d3450 lines 128-129</p>
            </div>
            <div class="claim-row">
              <span>artifact</span>
              <p>~/.pc/state/{'{uuid}'}/wiki/guides/project-positioning.md:<em>18</em></p>
            </div>
            <div class="badge-row">
              <span class="badge is-blue">explicit</span>
              <span class="badge is-green">verified</span>
              <span class="badge is-cyan">current</span>
            </div>
          </article>
        </div>

        <div class="problem-grid">
          <article class="surface problem-card">
            <span class="card-sigil">01</span>
            <h3>Repeated direction</h3>
            <p>The same product judgment gets explained again because it was never made durable.</p>
          </article>
          <article class="surface problem-card">
            <span class="card-sigil">02</span>
            <h3>Stale summaries</h3>
            <p>A summary can sound coherent while erasing reversals, uncertainty, and provenance.</p>
          </article>
          <article class="surface problem-card">
            <span class="card-sigil">03</span>
            <h3>Context landfill</h3>
            <p>Dumping everything into the prompt wastes the model's attention. Selection is the product.</p>
          </article>
        </div>
      </section>

      <section id="agent-mess" class="section mess-section" aria-labelledby="mess-heading">
        <div class="section-intro">
          <p class="eyebrow">The current agent mess</p>
          <h2 id="mess-heading">Built for the current agent mess.</h2>
          <p>
            Developers are stitching together AGENTS.md, CLAUDE.md, Cursor rules, MCP memory,
            markdown notes, vector stores, shell hooks, git logs, and manual rituals just to keep agents pointed in the right direction.
          </p>
          <p>
            That is not a workflow. It is folklore. pc turns the useful parts into a system:
            capture after the session, reconcile into cited artifacts, inject before action, and leave an audit trail.
          </p>
        </div>

        <div class="mess-grid">
          <article class="surface list-panel is-red">
            <h3>Before pc</h3>
            <ul>
              {messBefore.map(([name, note]) => (
                <li>
                  <code>{name}</code>
                  <span>{note}</span>
                </li>
              ))}
            </ul>
          </article>
          <article class="surface list-panel is-green">
            <h3>With pc</h3>
            <ul>
              {messAfter.map(([name, note]) => (
                <li>
                  <code>{name}</code>
                  <span>{note}</span>
                </li>
              ))}
            </ul>
          </article>
        </div>
      </section>

      <PipelineDiagram />

      <section class="section control-section" aria-labelledby="control-heading">
        <div class="section-intro">
          <p class="eyebrow">Context discipline</p>
          <h2 id="control-heading">Context engineering is the new control plane.</h2>
          <p>
            Prompt engineering told the model what to do. Context engineering decides what the model is allowed to know right now.
            pc gives that control plane a memory: cited, scoped, current, and injected before the agent acts.
          </p>
        </div>

        <div class="control-grid">
          <article class="surface control-card is-amber">
            <h3>Static context is a blunt instrument.</h3>
            <p>
              AGENTS.md and CLAUDE.md are useful. They are also blunt. A file loaded every session has no idea what the agent is about to do.
            </p>
            <div class="stack-diagram">
              <span>AGENTS.md <small>stable repo entrypoint</small></span>
              <span>CLAUDE.md <small>host-specific behavior</small></span>
              <span>~/.pc/state/{'{uuid}'}/wiki/ <small>materialized cited project knowledge</small></span>
              <span>pc inject <small>relevant slice for this prompt</small></span>
            </div>
          </article>

          <article class="surface control-card is-magenta">
            <h3>Instructions are not memory.</h3>
            <p>
              A standing instruction file is useful for stable basics. It is not a prompt-specific authority model.
              Memory is not truth. Truth needs provenance.
            </p>
            <TerminalCard title="pre-action injection" compact>
              <div class="terminal-row muted">User prompt: "Should we make this generic?"</div>
              <div class="terminal-row is-magenta">TITLE: Relevant project direction</div>
              <div class="terminal-row">The project has repeatedly rejected generic memory positioning.</div>
              <div class="terminal-row muted">Source: ~/.pc/state/{'{uuid}'}/wiki/guides/positioning.md:18</div>
            </TerminalCard>
          </article>

          <article class="surface control-card is-cyan">
            <h3>Summaries are not provenance.</h3>
            <p>
              A summary can keep the agent moving and still erase why a decision mattered.
              pc captures cited claims from completed sessions outside the shrinking context window.
            </p>
            <p class="callout-line">Compaction preserves continuity. pc preserves evidence.</p>
          </article>

          <article class="surface control-card is-blue">
            <h3>The harness matters.</h3>
            <p>
              A coding agent is not just a model. It is prompts, tools, memory, compaction, cache behavior,
              hooks, permissions, retrieval, and hidden state.
            </p>
            <div class="harness-stack" aria-label="Harness stack">
              <span>human judgment</span>
              <span>pc capture</span>
              <span>cited wiki</span>
              <span>pc inject</span>
              <span>system prompt</span>
              <span>tool use</span>
              <span>agent action</span>
            </div>
          </article>
        </div>
      </section>

      <section id="artifacts" class="section artifacts-section" aria-labelledby="artifacts-heading">
        <div class="section-intro">
          <p class="eyebrow">Artifact system</p>
          <h2 id="artifacts-heading">Four artifacts. One job each.</h2>
          <p>
            pc does not pretend one storage shape fits every kind of knowledge.
            Current truth, historical reversals, investigations, and lossless claims need different forms.
          </p>
        </div>

        <div class="artifact-grid">
          {artifacts.map((item) => <ArtifactCard item={item} />)}
        </div>
        <EpisodeCard />
      </section>

      <section class="section injection-section" aria-labelledby="injection-heading">
        <div class="section-intro">
          <p class="eyebrow">Hot-path injection</p>
          <h2 id="injection-heading">The agent should not have to remember to remember.</h2>
          <p>
            Tool-call memory is brittle. The agent has to notice it needs context, choose the right tool,
            query the right thing, and interpret what comes back.
          </p>
          <p>
            pc moves the critical path earlier. It selects and injects relevant project knowledge before the agent acts.
          </p>
        </div>

        <div class="injection-grid">
          <article class="injection-demo surface is-magenta">
            <div class="prompt-card">
              <span>User prompt</span>
              <p>"Should we make this generic?"</p>
            </div>
            <div class="reminder-card">
              <span>Injected reminder</span>
              <h3>TITLE: Relevant project direction</h3>
              <p>
                The project has repeatedly rejected generic memory positioning. Position around
                cited human discernment and project-specific provenance.
              </p>
              <code>Source: ~/.pc/state/{'{uuid}'}/wiki/guides/project-positioning.md:<em>18</em></code>
            </div>
          </article>

          <TerminalCard title="pc tail" label="audit trace">
            <div class="terminal-row event"><span>14:02:11</span><span>a3f</span><span>proactive</span><span class="is-magenta">▶ inject.start</span><span>"Should we make this generic?"</span></div>
            <div class="terminal-row event"><span>14:02:11</span><span>a3f</span><span>proactive</span><span class="is-blue">⟜ select.sources</span><span>2 guides · 1 episode</span></div>
            <div class="terminal-row event"><span>14:02:12</span><span>a3f</span><span>proactive</span><span class="is-magenta">✎ briefing</span><span>287c · cited</span></div>
            <div class="terminal-row event"><span>14:02:12</span><span>a3f</span><span>proactive</span><span class="is-green">✓ inject.done</span><span>1.2s · compiled</span></div>
          </TerminalCard>
        </div>

        <p class="audit-callout">Injection without audit is just another hidden prompt.</p>
      </section>

      <section class="section supersession-section" aria-labelledby="supersession-heading">
        <div class="section-intro">
          <p class="eyebrow">Staleness and supersession</p>
          <h2 id="supersession-heading">Current truth, with history.</h2>
          <p>
            When direction changes, pc does not erase the old state and does not inject it as current truth.
            Superseded direction is demoted, linked, and preserved as product archaeology.
          </p>
        </div>
        <div class="supersession-grid">
          <article class="supersession-card old surface is-warning">
            <span class="badge is-warning">old belief</span>
            <p>"We use Jest."</p>
          </article>
          <article class="supersession-card episode surface is-amber">
            <span class="badge is-amber">episode</span>
            <p>~/.pc/state/{'{uuid}'}/wiki/episodes/2026-03-18-test-runner-migration.md</p>
          </article>
          <article class="supersession-card current surface is-green">
            <span class="badge is-green">current truth</span>
            <p>"We use Vitest for package tests."</p>
          </article>
          <article class="supersession-card briefing surface is-magenta">
            <span class="badge is-magenta">injected briefing</span>
            <p>Use Vitest for new package tests. Jest references are historical unless touching legacy packages.</p>
            <div class="badge-row">
              <span class="badge is-amber">superseded → current</span>
              <span class="badge is-stone">historical · not injected as truth</span>
            </div>
          </article>
        </div>
      </section>

      <section id="surfaces" class="section surfaces-section" aria-labelledby="surfaces-heading">
        <div class="section-intro">
          <p class="eyebrow">Product surfaces</p>
          <h2 id="surfaces-heading">A CLI for the whole context lifecycle.</h2>
          <p>
            The system stays close to the workflows serious agent users already trust:
            local binaries, hooks, markdown, JSONL, git, and terminal inspection.
          </p>
        </div>

        <div class="command-grid">
          {commands.map((item) => <CommandCard item={item} />)}
        </div>
      </section>

      <section id="evals" class="section evals-section" aria-labelledby="evals-heading">
        <div class="section-intro">
          <p class="eyebrow">Evals and proof</p>
          <h2 id="evals-heading">Do not trust memory without evals.</h2>
          <p>
            Agent memory is easy to demo and hard to validate. A memory system can retrieve something plausible
            and still fail the real test: did it prevent the user from repeating a correction?
          </p>
          <p>
            pc is evaluated against future sessions, not toy prompts. Past sessions build the store.
            Future sessions reveal whether the right correction, reversal, or constraint surfaced before the user had to repeat it.
          </p>
        </div>

        <div class="metric-grid">
          {metrics.map((item) => <EvalMetricCard item={item} />)}
        </div>

        <blockquote class="research-quote">
          <p>
            The architecture has scars. Claims-only projection failed. Raw context dumps failed.
            Retrieval blending failed. Uncertainty-gated injection failed. The current hybrid exists because the evals forced it.
          </p>
        </blockquote>
      </section>

      <section class="section fit-section" aria-labelledby="fit-heading">
        <div class="section-intro">
          <p class="eyebrow">Where pc fits</p>
          <h2 id="fit-heading">Not another memory bucket.</h2>
          <p>
            Most agent memory systems answer the easy question: can we store something?
            pc answers the harder questions: what deserves to persist, what is current,
            what was superseded, what evidence supports it, and what should be injected now?
          </p>
        </div>

        <div class="comparison-table-wrap surface">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>Pattern</th>
                <th>Where it breaks</th>
                <th>pc answer</th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row) => (
                <tr>
                  <td>{row.pattern}</td>
                  <td>{row.failure}</td>
                  <td>{row.answer}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="section refusals-section" aria-labelledby="refusals-heading">
        <div class="section-intro">
          <p class="eyebrow">Product boundaries</p>
          <h2 id="refusals-heading">Refusals are part of the product.</h2>
          <p>
            Vague memory systems rot. pc is opinionated about what it will not do.
          </p>
        </div>

        <div class="refusal-grid">
          {refusals.map((item) => <RefusalCard item={item} />)}
        </div>
      </section>

      <InstallBlock />
      <FinalCTA />
    </main>
    <Footer />
    <script is:inline>
      const copyButtons = Array.from(document.querySelectorAll("[data-copy]"));
      copyButtons.forEach((button) => {
        button.addEventListener("click", async () => {
          const text = button.getAttribute("data-copy") || "";
          try {
            await navigator.clipboard.writeText(text);
            button.textContent = "✓ copied";
            button.setAttribute("aria-live", "polite");
            window.setTimeout(() => {
              button.textContent = "copy";
            }, 1600);
          } catch {
            button.textContent = "copy failed";
          }
        });
      });
    </script>
  </body>
</html>
