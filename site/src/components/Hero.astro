---
import CitationChip from "@components/CitationChip.astro";
import TerminalCard from "@components/TerminalCard.astro";
import { trustItems } from "@data/home";
---

<section id="top" class="hero section" aria-labelledby="hero-heading">
  <div class="hero-copy" data-reveal>
    <p class="eyebrow">Provenance-first context infrastructure for AI agents</p>
    <h1 id="hero-heading">Stop losing the decisions behind the work.</h1>
    <p class="hero-subhead">
      pc captures the corrections, decisions, reversals, and project judgment buried in agent sessions.
      It distills them into cited repo-native artifacts, then injects the relevant slice before future agents act.
    </p>
    <p class="hero-maxim">
      Every correction is expensive human judgment. <code>pc</code> makes sure you only have to give it once.
    </p>
    <div class="hero-actions">
      <a class="button primary" href="#install">Install pc</a>
      <a class="button secondary" href="#how-it-works">Read how it works</a>
    </div>
    <ul class="trust-strip" aria-label="Product properties">
      {trustItems.map((item) => <li>{item}</li>)}
    </ul>
  </div>

  <div class="hero-instrument" aria-label="Capture to wiki to inject flow" data-reveal>
    <div class="provenance-flow">
      <article class="flow-column">
        <span class="flow-label">Transcript</span>
        <div class="evidence-lines">
          <span><b>127</b> user: No, not generic memory.</span>
          <span><b>128</b> user: Preserve provenance.</span>
          <span><b>129</b> user: The correction is the asset.</span>
        </div>
      </article>
      <span class="flow-link" aria-hidden="true"></span>
      <article class="flow-column">
        <span class="flow-label">Wiki</span>
        <code>docs/wiki/guides/project-positioning.md</code>
        <div class="badge-row">
          <span class="badge is-green">verified</span>
          <span class="badge is-blue">explicit</span>
          <span class="badge is-cyan">current</span>
        </div>
      </article>
      <span class="flow-link" aria-hidden="true"></span>
      <article class="flow-column">
        <span class="flow-label">Inject</span>
        <p>The product is positioned around cited human discernment, not generic memory.</p>
        <CitationChip tone="magenta">(docs/wiki/guides/project-positioning.md:18)</CitationChip>
      </article>
    </div>

    <TerminalCard title="$ pc" label="hook trace">
      <div class="terminal-row command">$ pc capture --in</div>
      <div class="terminal-row is-blue">◆ distilling session</div>
      <div class="terminal-row muted">  extracted 17 cited claims</div>
      <div class="terminal-row muted">  updated docs/wiki/guides/inject-pipeline.md</div>
      <div class="terminal-row muted">  wrote episode card: "raw dumps replaced by selective injection"</div>
      <div class="terminal-gap"></div>
      <div class="terminal-row command">$ pc inject</div>
      <div class="terminal-row is-cyan">▶ selecting relevant sources</div>
      <div class="terminal-row is-magenta">✎ compiled 312c briefing</div>
      <div class="terminal-row is-green">✓ injected system reminder</div>
    </TerminalCard>

    <div class="status-citations">
      <span class="statusline">⬡ ✎ 312c · 14g</span>
      <div>
        <CitationChip>(docs/wiki/guides/inject-pipeline.md:42)</CitationChip>
        <CitationChip tone="blue">(docs/wiki/episodes/2026-06-04-context-dump-reversal.md:18)</CitationChip>
      </div>
    </div>
  </div>
</section>
