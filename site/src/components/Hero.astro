---
import CitationChip from "@components/CitationChip.astro";
import TerminalCard from "@components/TerminalCard.astro";
import { trustItems } from "@data/home";
---

<section id="top" class="hero section" aria-labelledby="hero-heading">
  <div class="hero-copy">
    <p class="eyebrow">Provenance-first context infrastructure for AI agents</p>
    <h1 id="hero-heading">Stop losing the decisions behind the work.</h1>
    <p class="hero-subhead">
      pc captures the corrections, decisions, reversals, and project judgment buried in agent sessions.
      It distills them into cited repo-native artifacts, then injects the relevant slice before future agents act.
    </p>
    <p class="hero-maxim">
      Every correction is expensive human judgment. <code>pc</code> makes sure you only have to give it once.
    </p>
    <div class="hero-actions">
      <a class="button primary" href="#install">Install pc</a>
      <a class="button secondary" href="#how-it-works">Read the architecture</a>
    </div>
    <ul class="trust-strip" aria-label="Product properties">
      {trustItems.map((item) => <li>{item}</li>)}
    </ul>
  </div>

  <div class="hero-instrument" aria-label="Capture to wiki to inject flow">
    <div class="provenance-flow hero-flow">
      <article class="flow-column">
        <span class="flow-label">Transcript</span>
        <div class="evidence-lines">
          <span><b>127</b> user: No, not generic memory.</span>
          <span><b>128</b> user: Preserve provenance.</span>
          <span><b>129</b> user: The correction is the asset.</span>
        </div>
      </article>
      <span class="flow-link" aria-hidden="true"></span>
      <article class="flow-column">
        <span class="flow-label">Wiki</span>
        <code>~/.pc/state/{'{uuid}'}/wiki/guides/project-positioning.md</code>
        <div class="badge-row">
          <span class="badge is-green">verified</span>
          <span class="badge is-blue">explicit</span>
          <span class="badge is-cyan">current</span>
        </div>
      </article>
      <span class="flow-link" aria-hidden="true"></span>
      <article class="flow-column">
        <span class="flow-label">Inject</span>
        <p>The product is positioned around cited human discernment, not generic memory.</p>
        <CitationChip tone="magenta">(~/.pc/state/{'{uuid}'}/wiki/guides/project-positioning.md:18)</CitationChip>
      </article>
    </div>

    <TerminalCard title="pc tail" label="local">
      <div class="terminal-row event"><span>14:02:08</span><span>a3f</span><span>proactive</span><span class="is-blue">◆ capture.start</span><span>Stop hook · session closed</span></div>
      <div class="terminal-row event"><span>14:02:09</span><span>a3f</span><span>proactive</span><span class="is-cyan">✚ claims</span><span>17 cited · explicit/implicit</span></div>
      <div class="terminal-row event"><span>14:02:10</span><span>a3f</span><span>proactive</span><span class="is-green">✓ wiki.update</span><span>~/.pc/state/{'{uuid}'}/wiki/guides/positioning.md</span></div>
      <div class="terminal-row event"><span>14:02:10</span><span>a3f</span><span>proactive</span><span class="is-amber">◆ episode</span><span>context-dump-reversal.md</span></div>
      <div class="terminal-gap"></div>
      <div class="terminal-row event"><span>14:02:11</span><span>a3f</span><span>proactive</span><span class="is-magenta">▶ inject.start</span><span>"Should we make this generic?"</span></div>
      <div class="terminal-row event"><span>14:02:11</span><span>a3f</span><span>proactive</span><span class="is-blue">⟜ select.sources</span><span>2 guides · 1 episode</span></div>
      <div class="terminal-row event"><span>14:02:12</span><span>a3f</span><span>proactive</span><span class="is-magenta">✎ briefing</span><span>287c · cited</span></div>
      <div class="terminal-row event"><span>14:02:12</span><span>a3f</span><span>proactive</span><span class="is-green">✓ inject.done</span><span>1.2s · compiled</span></div>
    </TerminalCard>

    <div class="status-citations">
      <span class="statusline">⬡ ✎ 287c · 14g</span>
      <div>
        <CitationChip>(~/.pc/state/{'{uuid}'}/wiki/guides/positioning.md:18)</CitationChip>
        <CitationChip tone="blue">(~/.pc/state/{'{uuid}'}/wiki/episodes/context-dump-reversal.md:12)</CitationChip>
      </div>
    </div>
  </div>
</section>
