---
import type { ArtifactItem } from "@data/home";

interface Props {
  item: ArtifactItem;
}

const { item } = Astro.props;
---

<article class={`artifact-card surface is-${item.tone}`}>
  <span class="card-glyph" aria-hidden="true">{item.glyph}</span>
  <div class="card-meta">
    <span class="badge">{item.label}</span>
    <code>{item.path}</code>
  </div>
  <h3>{item.title}</h3>
  <p>{item.body}</p>
  <div class="badge-row card-badges" aria-label={`${item.title} properties`}>
    {item.badges.map((badge) => <span class="badge">{badge}</span>)}
  </div>
</article>
