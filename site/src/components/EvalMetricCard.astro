---
import type { MetricItem } from "@data/home";

interface Props {
  item: MetricItem;
}

const { item } = Astro.props;
---

<article class={`metric-card surface is-${item.tone}`}>
  <span class="metric-sigil">{item.glyph}</span>
  <h3>{item.metric}</h3>
  <p>{item.question}</p>
  <span class="metric-label">{item.label}</span>
</article>
